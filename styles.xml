package com.recettealarm.app;
import android.app.*;import android.content.*;import android.graphics.Typeface;import android.os.*;import android.widget.*;
public class AdminActivity extends Activity{DB db;public void onCreate(Bundle b){super.onCreate(b);db=new DB(this);draw();}
 void draw(){LinearLayout r=UI.root(this);Button back=UI.whiteBtn(this,"← Retour");r.addView(back);back.setOnClickListener(v->finish());r.addView(UI.tv(this,"Admin Recette",31,Typeface.BOLD));r.addView(UI.muted(this,"Gestion rapide, conversions et partage.",15));r.addView(UI.hero(this,"⚙️","Centre de contrôle","Gère les recettes et aide ta femme à cuisiner plus vite."));
 LinearLayout stats=UI.section(this);stats.addView(UI.tv(this,"Résumé",22,Typeface.BOLD));stats.addView(UI.smallCard(this,"🍽 Recettes : "+db.count("recipes")));stats.addView(UI.smallCard(this,"🥕 Ingrédients : "+db.count("ingredients")));stats.addView(UI.smallCard(this,"🔥 Étapes programmées : "+db.count("steps")));r.addView(stats);
 Button add=UI.btn(this,"+ Ajouter une recette");r.addView(add);add.setOnClickListener(v->startActivity(new Intent(this,EditRecipeActivity.class)));Button shop=UI.whiteBtn(this,"🛒 Générer / partager liste de courses");r.addView(shop);shop.setOnClickListener(v->share(db.shoppingList()));Button conv=UI.oliveBtn(this,"📐 Voir conversions utiles");r.addView(conv);conv.setOnClickListener(v->showText("Conversions",db.conversions()));Button backup=UI.whiteBtn(this,"💾 Sauvegarde texte des courses");r.addView(backup);backup.setOnClickListener(v->share(db.shoppingList()+"\n\n---\n"+db.conversions()));
 r.addView(UI.tv(this,"Ce qui est inclus",22,Typeface.BOLD));r.addView(UI.smallCard(this,"✅ Recettes dynamiques\n✅ Images depuis téléphone\n✅ Plusieurs liens vidéo\n✅ Ratings ★★★★★\n✅ Température par étape\n✅ Alarmes anti-brûlure\n✅ Liste de courses automatique\n✅ Conversions verre/litre/ml/cuillère"));}
 void showText(String title,String msg){new AlertDialog.Builder(this).setTitle(title).setMessage(msg).setPositiveButton("OK",null).show();}void share(String s){startActivity(Intent.createChooser(new Intent(Intent.ACTION_SEND).setType("text/plain").putExtra(Intent.EXTRA_TEXT,s),"Partager"));}}
