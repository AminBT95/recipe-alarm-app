package com.recettealarm.app;
import android.app.*;import android.content.*;import android.database.*;import android.graphics.Typeface;import android.os.*;import android.widget.*;
public class FavoritesActivity extends Activity{DB db;LinearLayout list;public void onCreate(android.os.Bundle b){super.onCreate(b);db=new DB(this);draw();}
 void draw(){LinearLayout r=UI.root(this);Button back=UI.whiteBtn(this,"← Retour");r.addView(back);back.setOnClickListener(v->finish());r.addView(UI.tv(this,"Favoris",31,Typeface.BOLD));list=new LinearLayout(this);list.setOrientation(LinearLayout.VERTICAL);r.addView(list);Cursor c=db.getReadableDatabase().rawQuery("SELECT * FROM recipes WHERE fav=1 ORDER BY id DESC",null);int n=0;while(c.moveToNext()){n++;long id=c.getLong(c.getColumnIndexOrThrow("id"));TextView row=UI.card(this,"❤️ "+c.getString(c.getColumnIndexOrThrow("title"))+"\n⏱ "+c.getInt(c.getColumnIndexOrThrow("time"))+" min  •  "+UI.stars(c.getInt(c.getColumnIndexOrThrow("rating"))));row.setOnClickListener(v->startActivity(new Intent(this,DetailActivity.class).putExtra("id",id)));list.addView(row);}c.close();if(n==0)list.addView(UI.smallCard(this,"Aucune recette favorite pour le moment."));}
}
